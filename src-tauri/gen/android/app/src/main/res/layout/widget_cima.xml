<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="12dp"
    android:background="@drawable/bg_widget_cima">

    <!-- Logo + Cima Sync - centrado -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/cima_logo"
            android:contentDescription="@string/cima_widget_logo_description"/>

        <TextView
            android:id="@+id/txt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cima_widget_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Inicio de sesión rápido - centrado arriba -->
    <TextView
        android:id="@+id/btn_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cima_widget_subtitle"
        android:textColor="#E0E0E0"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <!-- Icono grande - ocupa espacio restante -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <ImageView
            android:id="@+id/img_center"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:scaleX="1.28"
            android:scaleY="1.28"
            android:src="@drawable/ic_signal_glass_offline_f1"
            android:contentDescription="@string/cima_widget_wifi_description"/>
    </FrameLayout>

    <!-- Estado de conexión -->
    <TextView
        android:id="@+id/txt_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cima_widget_status_offline"
        android:textColor="#B0B0B0"
        android:textSize="11sp"
        android:layout_marginTop="4dp"/>
</LinearLayout>
