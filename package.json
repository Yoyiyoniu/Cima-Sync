{
	"name": "cima-sync",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"description": "Autenticación automática para la red WiFi de la Universidad Autónoma de Baja California",
	"author": "Rodrigo Gibran Felix Leon",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Yoyiyoniu/Cima-Sync.git"
	},
	"keywords": [
		"uabc",
		"wifi",
		"authentication",
		"tauri",
		"rust",
		"react"
	],
	"scripts": {
		"dev": "vite --host",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"tauri": "tauri",
		"build:windows": "PATH=\"$HOME/.cargo/bin:$PATH\" bun tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc && ./scripts/check-builds-windows.sh",
		"build:linux": "./scripts/build-linux.sh && ./scripts/check-builds-linux.sh",
		"builder": "bun tui/cli.tsx"
	},
	"dependencies": {
		"@fontsource-variable/nunito": "^5.2.7",
		"@reactour/tour": "^3.8.0",
		"@tailwindcss/vite": "^4.3.0",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-autostart": "~2.5.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-os": "~2.3.2",
		"@tauri-apps/plugin-sql": "~2.3.2",
		"i18next": "^25.10.10",
		"motion": "^12.40.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-i18next": "^15.7.4",
		"react-router": "^7.15.1",
		"tailwindcss": "^4.3.0",
		"tauri-plugin-network-api": "^2.0.5",
		"tauri-plugin-widget-api": "^0.1.1",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"ink": "^5.2.0",
		"@inkjs/ui": "^2.0.0",
		"execa": "^9.5.0",
		"@tauri-apps/cli": "^2.11.2",
		"@types/react": "^18.3.29",
		"@types/react-dom": "^18.3.7",
		"@vitejs/plugin-react": "^4.7.0",
		"mermaid": "^11.15.0",
		"typescript": "~5.6.3",
		"vite": "^7.3.3",
		"vitepress": "^1.6.4",
		"vitepress-mermaid-viewer": "^0.4.0"
	}
}
